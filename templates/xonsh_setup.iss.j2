; Inno Setup script for xonsh
; Generated by xonsh-winget build.xsh — do not edit the output manually.

#define MyAppName "xonsh"
#define MyAppVersion "{{ version }}"
#define MyAppPublisher "Xonsh"
#define MyAppURL "https://xon.sh"
#define MyAppExeName "xonsh.exe"

[Setup]
AppId={{ app_guid }}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
AppVerName={#MyAppName} {#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
AppSupportURL=https://github.com/xonsh/xonsh/issues
DefaultDirName={localappdata}\Programs\{#MyAppName}
DefaultGroupName={#MyAppName}
AllowNoIcons=yes
{% if license_file -%}
LicenseFile={{ license_file }}
{% endif -%}
OutputDir={{ output_dir }}
OutputBaseFilename={{ output_filename }}
Compression=lzma2
SolidCompression=yes
WizardStyle=modern
{% if arch == 'x64' -%}
ArchitecturesAllowed=x64compatible
{% elif arch == 'arm64' -%}
ArchitecturesAllowed=arm64
{% endif -%}
ChangesEnvironment=yes
UninstallDisplayIcon={app}\Scripts\{#MyAppExeName}
SetupLogging=yes
CloseApplications=yes
PrivilegesRequired=lowest

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Tasks]
Name: "addtopath"; Description: "Add xonsh to user PATH"; GroupDescription: "Additional options:"

[Files]
Source: "{{ source_dir }}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\{#MyAppName}"; Filename: "{app}\Scripts\{#MyAppExeName}"
Name: "{group}\Uninstall {#MyAppName}"; Filename: "{uninstallexe}"

[Registry]
Root: HKCU; Subkey: "Environment"; \
    ValueType: expandsz; ValueName: "Path"; ValueData: "{olddata};{app}\Scripts"; \
    Tasks: addtopath; Check: NeedsAddPath(ExpandConstant('{app}\Scripts'))

[Code]
function NeedsAddPath(Param: string): boolean;
var
  OrigPath: string;
begin
  if not RegQueryStringValue(HKCU,
    'Environment',
    'Path', OrigPath)
  then begin
    Result := True;
    exit;
  end;
  Result := Pos(';' + Param + ';', ';' + OrigPath + ';') = 0;
end;
